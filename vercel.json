{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "corepack enable && pnpm install --frozen-lockfile && uv sync --frozen",
  "buildCommand": "uv run python src/build.py --output dist --production",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false
}